# ── Supabase (dari Settings > API) ──────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── WhatsApp (nomor owner tanpa tanda +) ─────────────
NEXT_PUBLIC_WA_NUMBER=6281234567890

# ── Session secret (buat string random panjang) ──────
AUTH_SECRET=ganti_dengan_random_string_minimal_32_karakter

# ── URL app (isi setelah deploy ke Vercel) ───────────
NEXTAUTH_URL=https://shiro-closing.vercel.app
